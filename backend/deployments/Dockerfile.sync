# ==========================================
# Stage 1: Build the Go binary
# ==========================================
FROM golang:1.25-alpine AS builder

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .

# Notice we target the sync-service main.go here
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-w -s" -o /sync-server ./cmd/sync-service

# ==========================================
# Stage 2: Create the tiny production image
# ==========================================
FROM alpine:latest

RUN apk --no-cache add ca-certificates

WORKDIR /root/

COPY --from=builder /sync-server .

# Expose the port your WebSocket server runs on.
EXPOSE 8082

CMD ["./sync-server"]

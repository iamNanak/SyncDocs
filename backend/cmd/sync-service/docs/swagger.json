{
  "schemes": ["http"],
  "swagger": "2.0",
  "info": {
    "description": "WebSocket endpoint for realtime collaboration.",
    "title": "SyncDocs Sync Service",
    "contact": {},
    "version": "1.0"
  },
  "basePath": "/",
  "paths": {
    "/ws/{id}": {
      "get": {
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "tags": ["sync"],
        "summary": "Connect to a document WebSocket",
        "parameters": [
          {
            "type": "string",
            "description": "Document ID (UUID)",
            "name": "id",
            "in": "path",
            "required": true
          }
        ],
        "responses": {
          "101": {
            "description": "Switching Protocols",
            "schema": {
              "type": "string"
            }
          },
          "400": {
            "description": "Bad Request",
            "schema": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "schema": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  },
  "securityDefinitions": {
    "BearerAuth": {
      "description": "Use \"Bearer \u003ctoken\u003e\"",
      "type": "apiKey",
      "name": "Authorization",
      "in": "header"
    }
  }
}
